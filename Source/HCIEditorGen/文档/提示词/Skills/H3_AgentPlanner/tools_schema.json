{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HCIAbilityKit H3 Agent Planner Tools Schema",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "variable_template_string": {
      "type": "string",
      "pattern": "^\\{\\{\\s*[A-Za-z0-9_]+\\.[A-Za-z0-9_]+(?:\\[\\d+\\])?\\s*\\}\\}$"
    },
    "game_or_variable_path": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^/Game/.*"
        },
        {
          "$ref": "#/definitions/variable_template_string"
        }
      ]
    }
  },
  "required": [
    "allowed_tools",
    "tool_args_json_schema",
    "plan_output_json_schema"
  ],
  "properties": {
    "allowed_tools": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "type": "string",
        "enum": [
          "ScanAssets",
          "ScanMeshTriangleCount",
          "SearchPath",
          "SetTextureMaxSize",
          "SetMeshLODGroup",
          "ScanLevelMeshRisks",
          "NormalizeAssetNamingByMetadata",
          "RenameAsset",
          "MoveAsset"
        ]
      },
      "uniqueItems": true
    },
    "tool_args_json_schema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ScanAssets",
        "ScanMeshTriangleCount",
        "SearchPath",
        "SetTextureMaxSize",
        "SetMeshLODGroup",
        "ScanLevelMeshRisks",
        "NormalizeAssetNamingByMetadata",
        "RenameAsset",
        "MoveAsset"
      ],
      "properties": {
        "ScanAssets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "directory": {
              "$ref": "#/definitions/game_or_variable_path"
            }
          }
        },
        "ScanMeshTriangleCount": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "directory": {
              "$ref": "#/definitions/game_or_variable_path"
            }
          }
        },
        "SearchPath": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "keyword"
          ],
          "properties": {
            "keyword": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            }
          }
        },
        "SetTextureMaxSize": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "asset_paths",
            "max_size"
          ],
          "properties": {
            "asset_paths": {
              "type": "array",
              "minItems": 1,
              "maxItems": 50,
              "x_requires_pipeline_input": true,
              "x_pipeline_source": {
                "tool_name": "ScanAssets",
                "evidence_key": "asset_paths"
              },
              "items": {
                "$ref": "#/definitions/game_or_variable_path"
              }
            },
            "max_size": {
              "type": "integer",
              "enum": [
                256,
                512,
                1024,
                2048,
                4096,
                8192
              ]
            }
          }
        },
        "SetMeshLODGroup": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "asset_paths",
            "lod_group"
          ],
          "properties": {
            "asset_paths": {
              "type": "array",
              "minItems": 1,
              "maxItems": 50,
              "x_requires_pipeline_input": true,
              "x_pipeline_source": {
                "tool_name": "ScanAssets",
                "evidence_key": "asset_paths"
              },
              "items": {
                "$ref": "#/definitions/game_or_variable_path"
              }
            },
            "lod_group": {
              "type": "string",
              "enum": [
                "LevelArchitecture",
                "SmallProp",
                "LargeProp",
                "Foliage",
                "Character"
              ]
            }
          }
        },
        "ScanLevelMeshRisks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scope",
            "checks",
            "max_actor_count"
          ],
          "properties": {
            "scope": {
              "type": "string",
              "enum": [
                "selected",
                "all"
              ]
            },
            "checks": {
              "type": "array",
              "minItems": 1,
              "maxItems": 2,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "missing_collision",
                  "default_material"
                ]
              }
            },
            "max_actor_count": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5000
            },
            "actor_names": {
              "type": "array",
              "minItems": 1,
              "maxItems": 50,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              }
            }
          }
        },
        "NormalizeAssetNamingByMetadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "asset_paths",
            "metadata_source",
            "prefix_mode",
            "target_root"
          ],
          "properties": {
            "asset_paths": {
              "type": "array",
              "minItems": 1,
              "maxItems": 50,
              "items": {
                "$ref": "#/definitions/game_or_variable_path"
              }
            },
            "metadata_source": {
              "type": "string",
              "enum": [
                "auto",
                "UAssetImportData",
                "AssetUserData"
              ]
            },
            "prefix_mode": {
              "type": "string",
              "enum": [
                "auto_by_asset_class"
              ]
            },
            "target_root": {
              "$ref": "#/definitions/game_or_variable_path"
            }
          }
        },
        "RenameAsset": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "asset_path",
            "new_name"
          ],
          "properties": {
            "asset_path": {
              "$ref": "#/definitions/game_or_variable_path"
            },
            "new_name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^[A-Za-z0-9_]+$"
            }
          }
        },
        "MoveAsset": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "asset_path",
            "target_path"
          ],
          "properties": {
            "asset_path": {
              "$ref": "#/definitions/game_or_variable_path"
            },
            "target_path": {
              "$ref": "#/definitions/game_or_variable_path"
            }
          }
        }
      }
    },
    "plan_output_json_schema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent",
        "route_reason",
        "steps"
      ],
      "properties": {
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "route_reason": {
          "type": "string",
          "minLength": 1
        },
        "assistant_message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        },
        "steps": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "step_id",
              "tool_name",
              "args",
              "expected_evidence"
            ],
            "properties": {
              "step_id": {
                "type": "string",
                "minLength": 1
              },
              "tool_name": {
                "type": "string",
                "enum": [
                  "ScanAssets",
                  "ScanMeshTriangleCount",
                  "SearchPath",
                  "SetTextureMaxSize",
                  "SetMeshLODGroup",
                  "ScanLevelMeshRisks",
                  "NormalizeAssetNamingByMetadata",
                  "RenameAsset",
                  "MoveAsset"
                ]
              },
              "args": {
                "type": "object"
              },
              "expected_evidence": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "ui_presentation": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "step_summary": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 120
                  },
                  "intent_reason": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 160
                  },
                  "risk_warning": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 200
                  }
                }
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "tool_name": {
                      "const": "SearchPath"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "args": {
                      "$ref": "#/properties/tool_args_json_schema/properties/SearchPath"
                    },
                    "expected_evidence": {
                      "items": {
                        "enum": [
                          "keyword", "keyword_expanded", "keyword_expanded_count", "matched_count", "matched_directories",
                          "best_directory", "semantic_fallback_used", "semantic_fallback_directory", "keyword_normalized",
                          "scanned_game_paths", "result"
                        ]
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "tool_name": {
                      "const": "ScanAssets"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "args": {
                      "$ref": "#/properties/tool_args_json_schema/properties/ScanAssets"
                    },
                    "expected_evidence": {
                      "items": {
                        "enum": [
                          "scan_root", "asset_count", "result", "asset_path", "asset_paths"
                        ]
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "tool_name": {
                      "const": "ScanMeshTriangleCount"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "args": {
                      "$ref": "#/properties/tool_args_json_schema/properties/ScanMeshTriangleCount"
                    },
                    "expected_evidence": {
                      "items": {
                        "enum": [
                          "scan_root", "scanned_count", "mesh_count", "max_triangle_count", "max_triangle_asset", "top_meshes", "result"
                        ]
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "tool_name": {
                      "const": "SetTextureMaxSize"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "args": {
                      "$ref": "#/properties/tool_args_json_schema/properties/SetTextureMaxSize"
                    },
                    "expected_evidence": {
                      "items": {
                        "enum": [
                          "target_max_size", "scanned_count", "modified_count", "failed_count", "modified_assets", "failed_assets", "result"
                        ]
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "tool_name": {
                      "const": "SetMeshLODGroup"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "args": {
                      "$ref": "#/properties/tool_args_json_schema/properties/SetMeshLODGroup"
                    },
                    "expected_evidence": {
                      "items": {
                        "enum": [
                          "target_lod_group", "scanned_count", "modified_count", "failed_count", "modified_assets", "failed_assets", "result"
                        ]
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "tool_name": {
                      "const": "ScanLevelMeshRisks"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "args": {
                      "$ref": "#/properties/tool_args_json_schema/properties/ScanLevelMeshRisks"
                    },
                    "expected_evidence": {
                      "items": {
                        "enum": [
                          "actor_path", "issue", "evidence",
                          "scope", "scanned_count", "risky_count", "risk_summary", "risky_actors", "missing_collision_actors", "default_material_actors", "result"
                        ]
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "tool_name": {
                      "const": "NormalizeAssetNamingByMetadata"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "args": {
                      "$ref": "#/properties/tool_args_json_schema/properties/NormalizeAssetNamingByMetadata"
                    },
                    "expected_evidence": {
                      "items": {
                        "enum": [
                          "result", "proposed_renames", "proposed_moves", "affected_count"
                        ]
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "tool_name": {
                      "const": "RenameAsset"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "args": {
                      "$ref": "#/properties/tool_args_json_schema/properties/RenameAsset"
                    },
                    "expected_evidence": {
                      "items": {
                        "enum": [
                          "asset_path", "before", "after", "result", "redirector_fixup", "redirector_count"
                        ]
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "tool_name": {
                      "const": "MoveAsset"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "args": {
                      "$ref": "#/properties/tool_args_json_schema/properties/MoveAsset"
                    },
                    "expected_evidence": {
                      "items": {
                        "enum": [
                          "asset_path", "before", "after", "result", "redirector_fixup", "redirector_count"
                        ]
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "steps": {
                "maxItems": 0
              }
            }
          },
          "then": {
            "required": [
              "assistant_message"
            ]
          }
        }
      ]
    }
  }
}
